{
  "name": "xmmusic",
  "productName": "xmmusic",
  "version": "1.1.2",
  "description": "音乐播放器",
  "main": "dist/electron/main/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "postinstall": "node scripts/install-app-deps.js",
    "rebuild": "node scripts/install-app-deps.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "cross-env NODE_ENV=production vite build",
    "build:electron": "cross-env NODE_ENV=production tsc -p tsconfig.electron.json && npm run copy:migrations",
    "copy:migrations": "node scripts/copy-migrations.js",
    "pack": "cross-env NODE_ENV=production electron-builder",
    "dist": "npm run build && cross-env NODE_ENV=production electron-builder",
    "dist:mac": "npm run build && cross-env NODE_ENV=production electron-builder --mac --arm64",
    "dist:win": "npm run build && cross-env NODE_ENV=production electron-builder --win --x64",
    "trigger:build": "gh workflow run build.yml",
    "trigger:watch": "gh run watch",
    "trigger:list": "gh run list --workflow=build.yml --limit=5",
    "trigger:script": "./scripts/trigger-build.sh",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "generate:icon": "node scripts/generate-icon.js"
  },
  "keywords": [
    "音乐",
    "播放器",
    "electron",
    "vue",
    "typescript"
  ],
  "author": {
    "name": "zdhsoft",
    "email": "zdhsoft@126.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/ui": "^4.1.10",
    "concurrently": "^9.2.4",
    "cross-env": "^7.0.3",
    "electron": "^42.7.0",
    "electron-builder": "^26.15.3",
    "typescript": "^7.0.2",
    "vite": "^7.2.2",
    "vitest": "^4.1.10",
    "vue": "^3.5.40",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "node-abi": "^4.33.0",
    "shell-quote": "^1.10.0",
    "rollup": "^4.62.2",
    "axios": "^1.18.1",
    "uuid": "^11.1.1"
  },
  "dependencies": {
    "@tanstack/vue-virtual": "^3.13.12",
    "@vueuse/core": "^14.3.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "colorthief": "^3.4.0",
    "exceljs": "^4.4.0",
    "fuse.js": "^7.5.0",
    "howler": "^2.2.4",
    "iconv-lite": "^0.7.3",
    "lucide-vue-next": "^0.554.0",
    "music-metadata": "^11.14.0",
    "node-id3": "^0.2.9",
    "pinia": "^4.0.2",
    "sortablejs": "^1.15.3",
    "vue-i18n": "^11.1.12",
    "vue-router": "^5.2.0",
    "vuedraggable": "^4.1.0"
  }
}
